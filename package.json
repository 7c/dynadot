{
  "name": "@7c/dynadot",
  "version": "2.0.6",
  "description": "library for interacting with Dynadot API v3",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "src/index.ts",
    "src/Dynadot.ts",
    "src/flatten.ts",
    "src/http.ts",
    "src/types.ts",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/7c/dynadot"
  },
  "keywords": [
    "dynadot",
    "domain api",
    "registar api"
  ],
  "author": "7c",
  "dependencies": {
    "debug": "^4.3.4",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "zod": "^4.4.2"
  }
}
